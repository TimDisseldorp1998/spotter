# Kopieer dit bestand naar .env.local en vul je eigen gegevens in.
# .env.local staat in .gitignore, dus die komt nooit in de repo terecht.
# Op Hostinger zet je dezelfde variabelen in hPanel bij de Node.js-app,
# niet in een bestand.

# SMTP van je Hostinger-mailpakket
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=jouw@disseldesign.com
SMTP_PASSWORD=

# Waar de aanmeldingen naartoe gemaild worden
SIGNUP_NOTIFY_TO=jouw@disseldesign.com
